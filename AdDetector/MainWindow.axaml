<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="AdDetector.MainWindow"
        Width="800" Height="600"
        Title="AdDetector">
    <StackPanel Margin="10" Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Name="indexButton" Content="Update Fingerprints"/>
            <Button Name="detectButton" Content="Detect Video"/>
            <Button Name="exitButton" Content="Exit" IsVisible="False"/>
        </StackPanel>
        <TextBlock Name="summary" Margin="0,10,0,10"/>
        <vlc:VideoView Name="videoView" Height="400"/>
    </StackPanel>
</Window>
